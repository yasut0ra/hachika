OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# OPENAI_TURN_MODEL=gpt-5-mini
# OPENAI_AUTONOMY_MODEL=gpt-5-mini
# OPENAI_INTERPRETER_MODEL=gpt-5-mini
# OPENAI_BEHAVIOR_MODEL=gpt-5-mini
# OPENAI_INITIATIVE_MODEL=gpt-5-mini
# OPENAI_PLANNER_MODEL=gpt-5-mini
# OPENAI_PROACTIVE_MODEL=gpt-5-mini
# OPENAI_TRACE_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=
# OPENAI_PROJECT=

# Lightweight local AI via an OpenAI-compatible endpoint.
# When HACHIKA_LOCAL_AI_BASE_URL is set, hachika uses it without requiring OPENAI_API_KEY.
# Examples:
#   LM Studio: http://127.0.0.1:1234/v1
#   Ollama OpenAI-compatible API: http://127.0.0.1:11434/v1
# HACHIKA_LOCAL_AI_BASE_URL=http://127.0.0.1:1234/v1
# HACHIKA_LOCAL_AI_MODEL=qwen2.5-7b-instruct
# HACHIKA_LOCAL_AI_API_KEY=local
# Optional per-role local models:
# HACHIKA_LOCAL_AI_TURN_MODEL=
# HACHIKA_LOCAL_AI_INTERPRETER_MODEL=
# HACHIKA_LOCAL_AI_BEHAVIOR_MODEL=
# HACHIKA_LOCAL_AI_INITIATIVE_MODEL=
# HACHIKA_LOCAL_AI_PLANNER_MODEL=
# HACHIKA_LOCAL_AI_PROACTIVE_MODEL=
# HACHIKA_LOCAL_AI_TRACE_MODEL=
# HACHIKA_LOCAL_AI_AUTONOMY_MODEL=
# HACHIKA_LOCAL_AI_REPLY_MODEL=

# HACHIKA_LOOP_INTERVAL_MS=15000
# HACHIKA_LOOP_IDLE_HOURS_PER_TICK=0.5
